import { createClient } from '@supabase/supabase-js'
const supabase = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL, process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY)
export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).end()
  const { vin, data } = req.body
  if (!vin) return res.status(400).json({ error: 'VIN required' })
  const { error } = await supabase.from('appraisals').upsert({ vin: vin.toUpperCase(), data, created_at: new Date().toISOString() }, { onConflict: 'vin' })
  if (error) return res.status(500).json({ error: error.message })
  return res.status(200).json({ url: `/appraisal/${vin.toUpperCase()}` })
}
